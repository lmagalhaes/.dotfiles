#!/usr/bin/env bash
# update-brewfile - Regenerate Brewfile from currently installed packages
#
# Uses `brew leaves` to list only user-installed formulae (excludes dependencies).
# Preserves special options (restart_service, args, etc.) from the existing Brewfile.
#
# Usage:
#   update-brewfile              # Updates ~/.dotfiles/Brewfile
#   update-brewfile /path/to/Brewfile

set -euo pipefail

# Requires bash 4+ for associative arrays (use brew-installed bash, not macOS default 3.2)
if (( BASH_VERSINFO[0] < 4 )); then
    echo "Error: bash 4+ required. Run with: $(brew --prefix)/bin/bash $0" >&2
    exit 1
fi

BREWFILE="${1:-$HOME/.dotfiles/Brewfile}"

# --- Parse existing Brewfile to preserve special options ---
# Always reads from the canonical dotfiles Brewfile so options survive preview runs.
# e.g. brew "dnsmasq", restart_service: true
#      brew "pyenv", args: ["HEAD"]
declare -A BREW_OPTS

OPTS_SOURCE="$HOME/.dotfiles/Brewfile"
if [[ -f "$OPTS_SOURCE" ]]; then
    while IFS= read -r line; do
        # Match: brew "name", <options>
        if [[ "$line" =~ ^brew[[:space:]]\"([^\"]+)\",[[:space:]](.+)$ ]]; then
            BREW_OPTS["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
        fi
    done < "$OPTS_SOURCE"
fi

# --- Collect current state ---
mapfile -t TAPS     < <(brew tap 2>/dev/null | sort)
mapfile -t FORMULAE < <(brew leaves 2>/dev/null | sort)
mapfile -t CASKS    < <(brew list --cask 2>/dev/null | sort)

# --- Generate Brewfile ---
{
    echo "# Homebrew packages - User installed only"
    echo "# Generated: $(date +%Y-%m-%d)"
    echo ""

    # Taps
    if (( ${#TAPS[@]} > 0 )); then
        echo "# Custom taps"
        for tap in "${TAPS[@]}"; do
            echo "tap \"$tap\""
        done
        echo ""
    fi

    # Formulae
    echo "# Formulae"
    for formula in "${FORMULAE[@]}"; do
        if [[ -v "BREW_OPTS[$formula]" ]]; then
            echo "brew \"$formula\", ${BREW_OPTS[$formula]}"
        else
            echo "brew \"$formula\""
        fi
    done
    echo ""

    # Casks
    if (( ${#CASKS[@]} > 0 )); then
        echo "# Casks"
        for cask in "${CASKS[@]}"; do
            echo "cask \"$cask\""
        done
        echo ""
    fi

} > "$BREWFILE"

echo "Brewfile updated: $BREWFILE"
printf "  Taps:     %d\n" "${#TAPS[@]}"
printf "  Formulae: %d\n" "${#FORMULAE[@]}"
printf "  Casks:    %d\n" "${#CASKS[@]}"
