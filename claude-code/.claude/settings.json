{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(~/.claude/set-cwd.sh *)",
      "Bash(/Users/lmagalhaes/.claude/set-cwd.sh *)",
      "Bash(*git rev-parse*)",
      "Bash(*git branch*)",
      "Bash(*git status*)",
      "Bash(*git log*)",
      "Bash(*git diff*)",
      "Bash(*git worktree list*)",
      "Bash(*pwd*)",
      "Bash(*dirname*)",
      "Bash(*realpath*)",
      "Bash(*cd*)",
      "Bash(*cat*)",
      "Bash(*ls*)",
      "Bash(*test*)",
      "Bash(*echo*)",
      "Bash(TZ=Australia/Sydney date *)",
      "Bash(*date*)",
      "Read(/Users/lmagalhaes/.claude/contexts/**)",
      "Read(/Users/lmagalhaes/.claude/contexts/*)",
      "Read(~/.claude/contexts/**)",
      "Read(~/.claude/contexts/*)",
      "Read(/Users/lmagalhaes/.claude/sessions/**)",
      "Read(/Users/lmagalhaes/.claude/sessions/*)",
      "Read(/Users/lmagalhaes/.dotfiles/.claude/sessions/**)",
      "Read(/Users/lmagalhaes/.dotfiles/.claude/sessions/*)",
      "Read(**/.claude/sessions/**)",
      "Read(**/.claude/sessions/*)",
      "Write(/Users/lmagalhaes/.claude/sessions/**)",
      "Write(/Users/lmagalhaes/.dotfiles/.claude/sessions/**)",
      "Write(**/.claude/sessions/**)"
    ],
    "deny": [
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(~/.env)",
      "Read(~/.env.*)",
      "Read(~/.netrc)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*.pem)",
      "Read(~/.ssh/*.key)",
      "Read(~/.ssh/authorized_keys)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.my.cnf)",
      "Read(~/.pgpass)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.config/op/**)",
      "Read(~/.op/**)",
      "Read(~/.vault-token)",
      "Read(~/.config/vault/**)",
      "Read(~/.codex/auth.json)",
      "Read(~/.codex/.credentials.json)",
      "Read(~/.claude/**/secrets/**)",
      "Read(~/.mcp/**/secrets/**)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); SID=$(echo \"$INPUT\" | jq -r \".session_id // empty\"); CWD=$(echo \"$INPUT\" | jq -r \".cwd // empty\"); [ -n \"$SID\" ] && rm -f \"/tmp/claude-cwd-${SID}\"; [ -n \"$CWD\" ] && [ -f /tmp/claude-sessions.json ] && jq --arg dir \"$CWD\" \"del(.[\\$dir])\" /tmp/claude-sessions.json > /tmp/claude-sessions.json.tmp && mv /tmp/claude-sessions.json.tmp /tmp/claude-sessions.json'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lmagalhaes/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true,
    "zoom-plugin@claude-plugins-official": false,
    "prime-context@workyard": true
  },
  "extraKnownMarketplaces": {
    "workyard": {
      "source": {
        "source": "directory",
        "path": "/Users/lmagalhaes/workspace/workyard/ai"
      }
    }
  },
  "theme": "dark-ansi",
  "editorMode": "vim",
  "feedbackSurveyState": {
    "lastShownTime": 1754024052158
  }
}
